{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug"
    }
  },
  "Keycloak": {
    "Authority": "http://localhost:8180/realms/order-management",
    "ClientId": "order-management-api"
  },
  "ReverseProxy": {
    "Clusters": {
      "order-cluster": {
        "Destinations": {
          "order-api": {
            "Address": "http://localhost:8081"
          }
        }
      },
      "catalog-cluster": {
        "Destinations": {
          "catalog-api": {
            "Address": "http://localhost:8082"
          }
        }
      }
    }
  }
}
