{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Yarp": "Information"
      }
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": []
  },
  "Keycloak": {
    "Authority": "http://localhost:8180/realms/order-management",
    "ClientId": "order-management-api"
  },
  "ReverseProxy": {
    "Routes": {
      "order-route": {
        "ClusterId": "order-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        }
      },
      "product-route": {
        "ClusterId": "catalog-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/api/products/{**catch-all}"
        }
      },
      "catalog-internal-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/internal/products/{**catch-all}"
        }
      },
      "order-health": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/services/order/health"
        },
        "Transforms": [
          { "PathSet": "/health" }
        ]
      },
      "catalog-health": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/services/catalog/health"
        },
        "Transforms": [
          { "PathSet": "/health" }
        ]
      }
    },
    "Clusters": {
      "order-cluster": {
        "Destinations": {
          "order-api": {
            "Address": "http://order-api:8080"
          }
        },
        "HttpClient": {
          "RequestHeaderEncoding": "utf-8"
        }
      },
      "catalog-cluster": {
        "Destinations": {
          "catalog-api": {
            "Address": "http://catalog-api:8080"
          }
        },
        "HttpClient": {
          "RequestHeaderEncoding": "utf-8"
        }
      }
    }
  }
}
